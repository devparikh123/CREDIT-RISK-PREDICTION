import pandas as pd
import numpy as np

df = pd.read_csv(r"C:\Users\parik\Downloads\credit_risk_dataset_1.csv")
print("Original Shape:", df.shape)
print(df.info())
print(df.head())
print(df.columns)

print("\nLoan Status Distribution:")
